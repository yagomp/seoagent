{
  "name": "@seoagent/core",
  "version": "0.1.3",
  "description": "Core library for SEOAgent — keyword research, rank tracking, site audits, competitor analysis, backlink intelligence, and AI-powered SEO strategy",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yagomp/seoagent.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/yagomp/seoagent#readme",
  "license": "MIT",
  "keywords": [
    "seo",
    "keyword-research",
    "rank-tracking",
    "site-audit",
    "backlinks",
    "competitor-analysis",
    "mcp",
